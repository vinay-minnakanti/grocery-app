# Backend Server
PORT=5000

# Database (AWS RDS - Retrieved from AWS Secrets Manager in production)
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your-password-from-secrets-manager
DB_NAME=grocery_db

# JWT Secret (Retrieved from AWS Secrets Manager in production)
JWT_SECRET=your-jwt-secret-from-secrets-manager
